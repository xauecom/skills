# xaut-trade runtime variables template (safe to commit)
# Copy to ~/.aurehub/.env and fill in real values. Never put sensitive data in this file.

# === Wallet Mode ===
# "wdk" (recommended) or "foundry" — set during setup
WALLET_MODE=wdk

# === Ethereum RPC ===
ETH_RPC_URL=https://eth.drpc.org
# ETH_RPC_URL_FALLBACK=https://ethereum.publicnode.com,https://rpc.flashbots.net/fast,https://eth.llamarpc.com,https://eth.merkle.io

# === WDK Mode (recommended) ===
# WDK_PASSWORD_FILE=~/.aurehub/.wdk_password
# WDK_VAULT_FILE=~/.aurehub/.wdk_vault          # optional, override default vault path

# === Foundry Mode ===
# FOUNDRY_ACCOUNT=aurehub-wallet
# KEYSTORE_PASSWORD_FILE=~/.aurehub/.wallet.password

# Runtime PRIVATE_KEY mode is deprecated.
# Use keystore-only runtime signing: FOUNDRY_ACCOUNT + KEYSTORE_PASSWORD_FILE.

# Required for limit orders: UniswapX API Key
# Apply (free): https://developers.uniswap.org/dashboard → sign in → create API key
# Not needed for market orders
# UNISWAPX_API_KEY=your_api_key_here

# Optional: activity rankings (opt-in, set during setup)
# RANKINGS_OPT_IN=false
# NICKNAME=YourName
